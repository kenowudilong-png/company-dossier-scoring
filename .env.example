# === LLM 网关 (YesYeah) ===
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_CLEAN=gpt-4o-mini
LLM_MODEL_SCORE=gpt-4o
LLM_MODEL_STUDIO=gpt-4o
LLM_MODEL_EMBED=text-embedding-3-small
EMBED_DIM=1536

# === 门阈 ===
REFUSAL_THRESHOLD=0.55
LOW_TRUST_THRESHOLD=0.4
RETRIEVAL_TOP_K_SCORING=12
RETRIEVAL_TOP_K_STUDIO=8

# === Postgres ===
DATABASE_URL=postgresql://ci:ci_dev@localhost:5432/companyintel
PG_HOST=postgres
PG_PORT=5432
PG_DB=companyintel
PG_USER=ci
PG_PASSWORD=ci_dev

# === Redis / Arq ===
REDIS_URL=redis://redis:6379/0
ARQ_QUEUE=parser_tasks

# === MinIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=company-intel-files

# === 服务互联 ===
PARSER_BASE_URL=http://localhost:8001
SCORING_BASE_URL=http://localhost:8002
STUDIO_BASE_URL=http://localhost:8003
